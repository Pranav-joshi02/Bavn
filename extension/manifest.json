{
  "manifest_version": 3,
  "name": "BAVN.io",
  "version": "2.0.0",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "identity"
  ],

  "host_permissions": [
    "https://docs.google.com/forms/*"
  ],

  "action": {
    "default_popup": "src/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*"],
      "js": ["dist/contentScript.js"],
      "all_frames": true
    }
  ]
}
